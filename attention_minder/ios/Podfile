platform :ios, '16.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
require File.expand_path(
  '.symlinks/plugins/google_mlkit_commons/ios/scripts/apple_silicon_simulator',
  __dir__,
)

flutter_ios_podfile_setup

# mediapipe_face_mesh 2.0.0 bundles a fat TensorFlowLiteC framework whose
# arm64 slice is labeled for iPhoneOS. Reuse the reversible ML Kit relabel
# build phase so that slice targets the active Apple platform (device or
# simulator) without changing its machine code.
def include_mediapipe_tflite_in_apple_silicon_patch(installer)
  patcher = File.join(
    installer.sandbox.root.to_s,
    'MLKitAppleSiliconSimulator',
    'patch_arm64_simulator.py',
  )
  return unless File.exist?(patcher)

  source = File.read(patcher)
  anchor = "    binaries = list(_iter_framework_binaries(args.pods_root))\n"
  addition = [
    "    mediapipe_tflite = os.path.realpath(os.path.join(\n",
    "        args.pods_root, '..', '.symlinks', 'plugins',\n",
    "        'mediapipe_face_mesh', 'ios', 'Frameworks',\n",
    "        'TensorFlowLiteC.framework', 'TensorFlowLiteC'))\n",
    "    if os.path.isfile(mediapipe_tflite):\n",
    "        binaries.append(mediapipe_tflite)\n",
  ].join
  return if source.include?('mediapipe_tflite = os.path.realpath')
  raise 'ML Kit Apple Silicon patch format changed' unless source.include?(anchor)

  File.write(patcher, source.sub(anchor, anchor + addition))

  target = installer.pods_project.targets.find do |candidate|
    candidate.name == 'mediapipe_face_mesh'
  end
  return if target.nil?

  phase_name = '[MediaPipe] Relabel TensorFlowLiteC for current platform'
  phase = target.shell_script_build_phases.find { |item| item.name == phase_name }
  phase ||= target.new_shell_script_build_phase(phase_name)
  phase.shell_path = '/bin/sh'
  phase.shell_script = <<~SH
    set -euo pipefail
    /usr/bin/env python3 "${PODS_ROOT}/MLKitAppleSiliconSimulator/patch_arm64_simulator.py" \
      --platform "${PLATFORM_NAME}" \
      --pods-root "${PODS_ROOT}"
  SH
  phase.always_out_of_date = '1' if phase.respond_to?(:always_out_of_date=)
  target.build_phases.delete(phase)
  target.build_phases.insert(0, phase)
  installer.pods_project.save
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'NO'
    end
  end
  mlkit_apple_silicon_simulator_patch(installer)
  include_mediapipe_tflite_in_apple_silicon_patch(installer)
end
